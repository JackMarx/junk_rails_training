<% content_for :title, "New Book" %>

<h1>New Book</h1>

<%= form_with model: @book do |f| %>
  <% if @book.errors.any? %>
    <div>
      <p><%= pluralize(@book.errors.count, "error") %> prevented this book from being saved:</p>
      <ul>
        <% @book.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :title %>
    <%= f.text_field :title %>
  </div>

  <div>
    <%= f.label :author %>
    <%= f.text_field :author %>
  </div>

  <div>
    <%= f.label :published_on, "Published On" %>
    <%= f.date_field :published_on %>
  </div>

  <div>
    <%= f.label :cost %>
    <%= f.number_field :cost, step: 0.01, min: 0 %>
  </div>

  <%= f.submit "Save Book" %>
<% end %>

<%= link_to "Back to Books", books_path %>
